# Copy this file to .env and fill in real values.
# .env is gitignored and blocked from Claude reads.
# NEVER put actual secrets in this file.

# SQLite database file path
DATABASE_PATH=wifibuddy.db

# Admin API credentials (used with HTTP Basic Auth)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password

# External services — none required for core functionality
# OpenStreetMap + Leaflet are used for maps (no API key needed)
